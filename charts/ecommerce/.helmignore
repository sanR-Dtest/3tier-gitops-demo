# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with '!'). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.swo
*~
*.bak
*.tmp
*.orig
*~
# Various IDEs
.idea/
*.sublime-project
*.sublime-workspace
.vscode/
*.swp
*.swo
*~
.DS_Store
# Chart testing
/ci
# /ci/**
